diff --git a/src/parse/macros/select.rs b/src/parse/macros/select.rs
new file mode 100644
index 0000000..0fb0a55
--- /dev/null
+++ b/src/tools/rustfmt/src/parse/macros/select.rs
@@ -0,0 +1,136 @@
+use rustc_ast::ast;
+use rustc_ast::token;
+use rustc_ast::tokenstream::TokenStream;
+use rustc_parse::exp;
+use rustc_span::Symbol;
+
+use crate::rewrite::RewriteContext;
+
+pub(crate) enum SelectArmKind {
+    /// `<pat> = <expr> [, if <guard>] => <block>`  (tokio and futures)
+    Future {
+        pat: Box<ast::Pat>,
+        expr: Box<ast::Expr>,
+        guard: Option<Box<ast::Expr>>,
+    },
+    /// `complete => <block>`  (futures only)
+    Complete,
+    /// `default => <block>`  (futures only)
+    Default,
+}
+
+pub(crate) struct SelectArm {
+    pub(crate) kind: SelectArmKind,
+    pub(crate) body: Box<ast::Block>,
+}
+
+pub(crate) struct ParsedSelectMacro {
+    pub(crate) biased: bool,
+    pub(crate) arms: Vec<SelectArm>,
+}
+
+pub(crate) fn parse_select(
+    context: &RewriteContext<'_>,
+    ts: TokenStream,
+) -> Option<ParsedSelectMacro> {
+    let mut parser = super::build_parser(context, ts);
+
+    macro_rules! parse_or {
+        ($method:ident $(,)* $($arg:expr),* $(,)*) => {
+            match parser.$method($($arg,)*) {
+                Ok(val) => {
+                    if parser.psess.dcx().has_errors().is_some() {
+                        parser.psess.dcx().reset_err_count();
+                        return None;
+                    } else {
+                        val
+                    }
+                }
+                Err(err) => {
+                    err.cancel();
+                    parser.psess.dcx().reset_err_count();
+                    return None;
+                }
+            }
+        }
+    }
+
+    // Helper: check whether the current token is a plain identifier with the given name.
+    let is_ident = |parser: &rustc_parse::parser::Parser<'_>, name: &str| {
+        parser
+            .token
+            .ident()
+            .map_or(false, |(id, _)| id.name == Symbol::intern(name))
+    };
+
+    // Optional `biased;` directive (tokio only, not a Rust keyword).
+    let biased = if is_ident(&parser, "biased") {
+        parser.bump();
+        if !parser.eat(exp!(Semi)) {
+            return None;
+        }
+        true
+    } else {
+        false
+    };
+
+    let mut arms = vec![];
+
+    while parser.token.kind != token::Eof {
+        // Check for `complete =>` and `default =>` (futures::select! special arms).
+        let kind = if is_ident(&parser, "complete") {
+            parser.bump();
+            if !parser.eat(exp!(FatArrow)) {
+                return None;
+            }
+            SelectArmKind::Complete
+        } else if is_ident(&parser, "default") {
+            parser.bump();
+            if !parser.eat(exp!(FatArrow)) {
+                return None;
+            }
+            SelectArmKind::Default
+        } else {
+            // `<pat> = <expr> [, if <guard>] => <block>`
+            let pat = parse_or!(parse_pat_no_top_alt, None, None);
+
+            if !parser.eat(exp!(Eq)) {
+                return None;
+            }
+
+            // `parse_expr` stops before `=>` since `=>` is not a valid expression operator.
+            let future_expr = parse_or!(parse_expr);
+
+            // Optional `, if <guard>`
+            let guard = if parser.eat(exp!(Comma)) {
+                if parser.eat_keyword(exp!(If)) {
+                    Some(parse_or!(parse_expr))
+                } else {
+                    // A lone comma before `=>` — not valid select! syntax.
+                    return None;
+                }
+            } else {
+                None
+            };
+
+            if !parser.eat(exp!(FatArrow)) {
+                return None;
+            }
+
+            SelectArmKind::Future {
+                pat,
+                expr: future_expr,
+                guard,
+            }
+        };
+
+        let body = parse_or!(parse_block);
+
+        // Optional trailing comma after the arm body.
+        let _ = parser.eat(exp!(Comma));
+
+        arms.push(SelectArm { kind, body });
+    }
+
+    Some(ParsedSelectMacro { biased, arms })
+}
