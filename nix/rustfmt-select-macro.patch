index 1c5d804..2bd2949 100644
--- a/src/tools/rustfmt/src/macros.rs
+++ b/src/tools/rustfmt/src/macros.rs
@@ -25,9 +25,11 @@ use crate::comment::{
 use crate::config::StyleEdition;
 use crate::config::lists::*;
 use crate::expr::{RhsAssignKind, rewrite_array, rewrite_assign_rhs};
+use crate::expr::rewrite_block_with_visitor;
 use crate::lists::{ListFormatting, itemize_list, write_list};
 use crate::overflow;
 use crate::parse::macros::lazy_static::parse_lazy_static;
+use crate::parse::macros::select::{SelectArmKind, parse_select};
 use crate::parse::macros::{ParsedMacroArgs, parse_expr, parse_macro_args};
 use crate::rewrite::{
     MacroErrorKind, Rewrite, RewriteContext, RewriteError, RewriteErrorExt, RewriteResult,
@@ -244,6 +246,24 @@ fn rewrite_macro_inner(
         }
     }
 
+    // Format tokio and futures select! macros.
+    if matches!(
+        macro_name.as_str(),
+        "select!" | "tokio::select!" | "futures::select!"
+    ) && !has_comment
+    {
+        match format_select_macro(context, shape, ts.clone(), mac.span(), &macro_name) {
+            Ok(rw) => return Ok(rw),
+            Err(err) => match err {
+                // Fall through to brace passthrough if we could not parse the select arms.
+                RewriteError::MacroFailure { kind, span: _ }
+                    if kind == MacroErrorKind::ParseFailure => {}
+                // If formatting fails after a successful parse, propagate the error.
+                _ => return Err(err),
+            },
+        }
+    }
+
     let ParsedMacroArgs {
         args: arg_vec,
         vec_with_semi,
@@ -1523,3 +1543,63 @@ fn rewrite_macro_with_items(
     result.push_str(trailing_semicolon);
     Ok(result)
 }
+
+fn format_select_macro(
+    context: &RewriteContext<'_>,
+    shape: Shape,
+    ts: TokenStream,
+    span: Span,
+    macro_name: &str,
+) -> RewriteResult {
+    let parsed = parse_select(context, ts).macro_error(MacroErrorKind::ParseFailure, span)?;
+
+    let arm_shape = shape
+        .block_indent(context.config.tab_spaces())
+        .with_max_width(context.config);
+
+    let mut result = String::with_capacity(1024);
+    result.push_str(macro_name);
+    result.push_str(" {");
+
+    let newline = arm_shape.indent.to_string_with_newline(context.config);
+    let closing_newline = shape.indent.to_string_with_newline(context.config);
+
+    if parsed.biased {
+        result.push_str(&newline);
+        result.push_str("biased;");
+    }
+
+    for arm in &parsed.arms {
+        result.push_str(&newline);
+
+        match &arm.kind {
+            SelectArmKind::Future { pat, expr, guard } => {
+                result.push_str(&pprust::pat_to_string(pat));
+                result.push_str(" = ");
+
+                let expr_str = expr.rewrite_result(context, arm_shape)?;
+                result.push_str(&expr_str);
+
+                if let Some(guard) = guard {
+                    let guard_str = guard.rewrite_result(context, arm_shape)?;
+                    result.push_str(", if ");
+                    result.push_str(&guard_str);
+                }
+            }
+            SelectArmKind::Complete => result.push_str("complete"),
+            SelectArmKind::Default => result.push_str("default"),
+        }
+
+        result.push_str(" =>");
+
+        // Handler block — use the full rustfmt block formatter.
+        let block_str =
+            rewrite_block_with_visitor(context, " ", &arm.body, None, None, arm_shape, true)?;
+        result.push_str(&block_str);
+    }
+
+    result.push_str(&closing_newline);
+    result.push('}');
+
+    Ok(result)
+}
